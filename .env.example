NODE_ENV=development
PORT=5000
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your_jwt_secret

# Platform DB (users, restaurants, plans) — raise under heavy concurrent traffic
# MONGO_MAX_POOL_SIZE=20

# Per-tenant restaurant databases (aktech_RESTOxxx): cache size + pool per tenant
# TENANT_DB_MAX_CONNECTIONS=128
# TENANT_DB_POOL_MAX=5

# Cap in-memory tenant lookup cache (after Restaurant.findOne); LRU eviction when full
# TENANT_LOOKUP_CACHE_MAX=400

# Comma-separated frontend origins for CORS in production (required if your Netlify URL is not in code defaults)
# Must match the exact browser origin: https://<your-site>.netlify.app (no trailing slash)
# CORS_ORIGINS=https://restowebtests.netlify.app

# Behind nginx/Render/load balancer — hops for express-rate-limit / secure IP (default 1 when NODE_ENV=production)
# TRUST_PROXY_HOPS=1

# Stripe Test Keys (Get from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Company & Email configuration
COMPANY_NAME="My Cafe"
COMPANY_EMAIL="your_email@example.com"

# SMTP Settings (for Payroll Emails)
# For Gmail: use smtp.gmail.com, port 587, and a Google App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password

# Shared secret for on-prem Print Connector (must match RESTO_CONNECTOR_TOKEN on POS PC)
PRINT_CONNECTOR_TOKEN=generate_a_long_random_secret

# App Settings
NODE_ENV=development
